<!-- templates/index.tmpl -->
{{define "index"}}
<!DOCTYPE html>
<html lang="en" class="dark">
{{template "head" .}}

<body
    class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-300 relative pb-16">
    <header class="max-w-4xl mx-auto mt-8 mb-8 text-center">
        <h1 class="text-4xl font-bold mb-2">{{ T "Title" }}</h1>
        <p class="text-lg text-gray-600 dark:text-gray-400">{{ T "IndexSubHeading"}}</p>
    </header>

    {{ template "language_select" . }}

    <section class="max-w-6xl mx-auto p-4 mb-6">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="md:col-span-2 prose dark:prose-invert max-w-none">
                <h2 class="text-2xl font-semibold mb-2">Hi there 👋</h2>
                I'm Wlczak - a developer based in Pilsen, Czechia. I mostly build web applications, but I also enjoy
                working
                with embedded systems for their straightforward, hands-on nature.
                <br><br>
                I primarily use PHP and Go for my personal projects, though I like trying out other languages from time
                to time. I'm currently interested in learning Rust and maybe Kotlin for native android development.
                <!-- <h3 class="mt-4 text-lg font-semibold">What I build</h3> -->
                <!-- <ul> -->
                <!-- <li>Web applications and APIs with pragmatic, maintainable backends</li> -->
                <!-- <li>Embedded projects and microcontroller tooling</li> -->
                <!-- <li>Small utilities to speed up developer workflows</li> -->
                <!-- </ul> -->
            </div>

            <aside class="flex flex-col items-center justify-center space-y-4">
                <h2 class="text-xl font-semibold mb-2">My main languages</h2>
                <div class="flex flex-wrap justify-center gap-2">
                    <img alt="PHP"
                        src="https://img.shields.io/badge/php-%23777BB4.svg?style=for-the-badge&logo=php&logoColor=white"
                        class="h-8" />
                    <img alt="Go"
                        src="https://img.shields.io/badge/go-%2300ADD8.svg?style=for-the-badge&logo=go&logoColor=white"
                        class="h-8" />
                    <img src="https://img.shields.io/badge/java-%23ED8B00.svg?style=for-the-badge&logo=openjdk&logoColor=white"
                        alt="Java">
                </div>
                <div class="w-full text-center">
                    <a href="https://github.com/Wlczak" target="_blank" rel="noopener noreferrer"
                        class="inline-block px-4 py-2 rounded-md bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-gray-100 hover:bg-gray-200 dark:hover:bg-gray-600">View
                        GitHub</a>
                </div>
            </aside>
        </div>
    </section>

    <header class="max-w-4xl mx-auto mt-8 mb-8 text-center">
        <h1 class="text-4xl font-bold mb-2">{{ T "Title" }}</h1>
        <p class="text-lg text-gray-600 dark:text-gray-400">{{ T "IndexSubHeading"}}</p>
    </header>

    <main class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 p-4">
        {{ range $key, $project := .Projects }}
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 flex flex-col transition-colors duration-300">
            <div class="flex flex-col flex-1 justify-between">
                <div>
                    <h2 class="text-xl font-semibold mb-2">{{ $project.Name }}</h2>
                    <p class="text-gray-700 dark:text-gray-300 mb-2">{{ T $project.Description }}</p>
                </div>
                {{ if $project.TechStack }}
                <div>
                    <div class="my-2 h-px w-full bg-gray-200 dark:bg-gray-700 rounded-full"></div>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Tech stack: {{ $project.TechStack }}</p>
                </div>
                {{ end }}
            </div>
            <div class="flex space-x-2 mt-4">
                {{ if $project.VisitButton.Link }}
                <a href="{{ if $project.VisitButton.Disabled }}#{{ else }}{{ $project.VisitButton.Link }}{{ end }}"
                    target="{{ if $project.VisitButton.Disabled }}_self{{ else }}_blank{{ end }}"
                    rel="{{ if $project.VisitButton.Disabled }}noopener{{ else }}noopener noreferrer{{ end }}"
                    title="{{ if $project.VisitButton.Title }}{{ $project.VisitButton.Title }}{{ end }}"
                    class="flex-1 text-center px-4 py-2 rounded-md font-medium transition {{ if $project.VisitButton.Disabled }}opacity-50 cursor-not-allowed pointer-events-none bg-gray-300 text-gray-600 dark:bg-gray-600 dark:text-gray-400{{ else }}bg-blue-600 text-white hover:bg-blue-700{{ end }}"
                    {{ if $project.VisitButton.Disabled }}aria-disabled="true" tabindex="-1" {{ end }}>
                    {{ if T $project.VisitButton.Text }}{{ T $project.VisitButton.Text }}{{ else }}
                    {{ T "Visit" }}{{ end }}
                </a>
                {{ end }}

                {{ if $project.GitHubButton.Link }}
                <a href="{{ if $project.GitHubButton.Disabled }}#{{ else }}{{ $project.GitHubButton.Link }}{{ end }}"
                    target="{{ if $project.GitHubButton.Disabled }}_self{{ else }}_blank{{ end }}"
                    rel="{{ if $project.GitHubButton.Disabled }}noopener{{ else }}noopener noreferrer{{ end }}"
                    title="{{ if $project.GitHubButton.Title }}{{ $project.GitHubButton.Title }}{{ end }}"
                    class="flex-1 text-center px-4 py-2 rounded-md font-medium transition {{ if $project.GitHubButton.Disabled }}opacity-50 cursor-not-allowed pointer-events-none bg-gray-200 text-gray-500 dark:bg-gray-600 dark:text-gray-400{{ else }}bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-600{{ end }}"
                    {{ if $project.GitHubButton.Disabled }}aria-disabled="true" tabindex="-1" {{ end }}>
                    {{ if T $project.GitHubButton.Text }}{{ T $project.GitHubButton.Text }}{{ else }}GitHub{{ end }}
                </a>
                {{ end }}
            </div>
        </div>
        {{ end }}
    </main>
    {{template "footer"}}
</body>

</html>
{{end}}